# ============================================
# Provider API Keys
# ============================================
# For cloud mode (api.letta.com):
# - LETTA_API_KEY required
# - LETTA_BASE_URL is optional (defaults to https://api.letta.com)
# - OPENAI_API_KEY optional (if using Letta cloud with your own key)
#
# For local mode (letta-server):
# - OPENAI_API_KEY required
# - LETTA_BASE_URL required (http://letta-server:8283)
# - LETTA_API_KEY optional (if using local server with your own key)
# ============================================

LETTA_API_KEY=your_letta_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Override default cloud URL
# LETTA_BASE_URL=https://api.letta.com
# For local server: LETTA_BASE_URL=http://letta-server:8283
